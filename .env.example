# ──────────────────────────────────────────────
# Confluence Cloud
# ──────────────────────────────────────────────
# Base URL of your Confluence instance (no trailing slash)
CONFLUENCE_BASE_URL=https://your-company.atlassian.net

# Atlassian account email used to generate the API token
CONFLUENCE_EMAIL=you@company.com

# API token — generate at:
# https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=your_api_token_here

# Comma-separated list of Confluence space keys to index.
# Run 1-fetch-confluence.py with this empty first to see available spaces.
CONFLUENCE_SPACE_KEYS=ENG,DOCS,HR

# ──────────────────────────────────────────────
# Index building (step 2)
# ──────────────────────────────────────────────
# OpenAI — used by PageIndex internally to build the hierarchical tree.
# PageIndex calls the LLM to analyse document structure during indexing.
# NOT used for retrieval — the agent uses Claude for reasoning.
OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────
# Agent (steps 4-6)
# ──────────────────────────────────────────────
# Anthropic — used by the pydantic-ai agent in 4-agent.py and the chatbot
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────
# MCP server URL (step 6 chatbot only)
# ──────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8052/sse
